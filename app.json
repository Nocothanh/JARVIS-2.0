{
  "expo": {
    "name": "NEXUS AI",
    "slug": "nexpo-20",
    "owner": "a_ss_org",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050a0e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nexus.ai",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "NEXUS AI uses the microphone for voice input in call mode.",
        "NSCameraUsageDescription": "NEXUS AI uses the camera for visual analysis features.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./adaptive-icon.png",
        "backgroundColor": "#050a0e"
      },
      "package": "com.nexus.ai",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./favicon.png",
      "name": "NEXUS AI",
      "shortName": "NEXUS",
      "description": "NEXUS AI — Sistema di Intelligenza Adattiva",
      "themeColor": "#00f5d4",
      "backgroundColor": "#050a0e"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050a0e",
          "image": "./splash.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bff5e923-a89e-4160-af5b-ab48a880f9c6"
      }
    }
  }
}
